{
	"info": {
		"_postman_id": "eca-mini-pos-collection",
		"name": "ECA Mini POS - Cloud Assignment",
		"description": "Full API collection for the Mini POS microservices project.\n\nServices:\n- Config Server (8888)\n- Eureka Server (8761)\n- API Gateway (8080)\n- User Service (8081) - Cloud SQL / H2\n- Product Service (8082) - Cloud Firestore + GCS Bucket\n- Order Service (8083) - Cloud Firestore\n\nAll requests go through the API Gateway at port 8080.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "gateway_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "product_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "order_id",
			"value": "",
			"type": "string"
		}
	],
