				{
					"name": "List Orders by User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Orders retrieved', function() {",
									"    pm.expect(pm.response.code).to.equal(200);",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{gateway_url}}/orders?userId={{user_id}}",
							"host": ["{{gateway_url}}"],
							"path": ["orders"],
							"query": [
								{
									"key": "userId",
									"value": "{{user_id}}"
								}
							]
						}
